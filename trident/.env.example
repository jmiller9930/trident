TRIDENT_ENV=development
TRIDENT_API_HOST=0.0.0.0
TRIDENT_API_PORT=8000
TRIDENT_WEB_PORT=3000
TRIDENT_DB_HOST=trident-db
TRIDENT_DB_PORT=5432
TRIDENT_DB_NAME=trident
TRIDENT_DB_USER=trident
TRIDENT_DB_PASSWORD=changeme_local_only
# ChromaDB (100D). Compose sets TRIDENT_CHROMA_HOST=trident-chroma. Empty host = ephemeral client (local pytest).
TRIDENT_CHROMA_HOST=
TRIDENT_CHROMA_PORT=8000
TRIDENT_CHROMA_LOCAL_PATH=
TRIDENT_LOG_LEVEL=INFO

# JWT (IMPL_001 control plane). Use a long random secret in production (HS256).
# TRIDENT_JWT_SECRET=
# TRIDENT_JWT_ACCESS_EXPIRE_MINUTES=30
# TRIDENT_JWT_REFRESH_EXPIRE_DAYS=7

# Model plane wiring (MODEL_ROUTER_001) — Ollama-compatible HTTP on internal LAN only.
# TRIDENT_MODEL_ROUTER_BASE_URL=http://172.20.2.230:11434
# TRIDENT_MODEL_ROUTER_SECONDARY_BASE_URL=http://172.20.1.66:11434
# TRIDENT_MODEL_PLANE_SECONDARY_ENABLED=false
# TRIDENT_MODEL_PLANE_SECONDARY_READY_URL=
# TRIDENT_MODEL_PLANE_CONNECT_TIMEOUT_SEC=2
# TRIDENT_MODEL_PLANE_READ_TIMEOUT_SEC=5
# TRIDENT_MODEL_PLANE_REQUEST_TIMEOUT_SEC=120
# TRIDENT_MODEL_PLANE_PROBE_RETRIES=2
# TRIDENT_MODEL_PLANE_CIRCUIT_BREAKER_THRESHOLD=3
# TRIDENT_MODEL_PLANE_CIRCUIT_BREAKER_TTL_SEC=60
# TRIDENT_MODEL_PLANE_TCP_PROBE_ENABLED=true
# MODEL_ROUTER_002 — governed EXTERNAL path uses Ollama via ModelPlaneRouterService (never IDE/MCP/Nike).
# TRIDENT_ENGINEER_USE_MODEL_PLANE=false
# TRIDENT_ENGINEER_MODEL_PLANE_PREFER_SECONDARY=false

# GitHub provider (GITHUB_001) — opt-in; all git endpoints return 503 unless ENABLED=true.
# TRIDENT_GITHUB_ENABLED=false
# TRIDENT_GITHUB_TOKEN=github_pat_XXXXXXXX    # fine-grained PAT; never commit this value
# TRIDENT_GITHUB_TOKEN_FILE=                  # path to secret-mount file (preferred over TOKEN)
# TRIDENT_GITHUB_API_BASE_URL=https://api.github.com
# TRIDENT_GITHUB_DEFAULT_ORG=                 # optional org slug for repo creation
# TRIDENT_GITHUB_API_TIMEOUT=30

# Nike orchestrator worker (100O)
TRIDENT_NIKE_POLL_SEC=2
TRIDENT_NIKE_MAX_ATTEMPTS=5
TRIDENT_NIKE_RETRY_BACKOFF_SEC=1

# Deployment (clawbot / reverse proxy).
# Default local compose: leave both empty (API at /api/*, nginx location /api/).
#
# Subpath deploy (e.g. UI at http://host:3000/, API proxied at /trident/api/):
#   TRIDENT_BASE_PATH=/trident
#   TRIDENT_PUBLIC_BASE_URL=   <-- MUST stay EMPTY for same-origin (nginx on web port). Non-empty + wrong origin → NetworkError in browser.
#
# Cross-origin API only if CORS + matching scheme/port are guaranteed (most deployments should leave this empty):
# TRIDENT_PUBLIC_BASE_URL=https://api.example.com/trident
TRIDENT_BASE_PATH=/trident
TRIDENT_PUBLIC_BASE_URL=

# Local docker desktop (browser hits API on host port): optional override for web container JS:
# TRIDENT_PUBLIC_BASE_URL=http://localhost:8000

# Postgres (used by docker-compose for trident-db)
POSTGRES_USER=trident
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=trident
